<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="dotcommerce_cron_sync"
             instance="DotCommerce\CronScheduler\Cron\SyncJobs"
             method="execute">
            <schedule>* * * * *</schedule>
        </job>
    </group>
</config>
